yarn lint-staged || exit $?

# Scan staged changes for secrets. Soft-skip if gitleaks isn't
# installed locally — CI will still catch anything that slips through.
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks git --pre-commit --staged --redact --no-banner -v || {
    echo ""
    echo "❌ gitleaks detected potential secrets in staged changes."
    echo "   If this is a false positive, add an allowlist entry to .gitleaks.toml."
    echo "   Do NOT bypass with --no-verify."
    exit 1
  }
else
  echo "⚠️  gitleaks not installed locally — skipping pre-commit secret scan."
  echo "   Install: brew install gitleaks    (CI will still scan this PR.)"
fi
